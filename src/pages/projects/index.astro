---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const projects = (await getCollection("projects")).sort((a, b) => {
  if (!(a.data.date || b.data.date)) {
    return 0;
  }
  if (!a.data.date) {
    return 1;
  }
  if (!b.data.date) {
    return -1;
  }
  return b.data.date.valueOf() - a.data.date.valueOf();
});

const statusLabel: Record<string, string> = {
  active: "Active",
  wip: "WIP",
  archived: "Archived",
};

const statusClass: Record<string, string> = {
  active: "badge-secondary",
  wip: "badge-outline",
  archived: "badge-outline",
};
---

<Layout title="Projects" currentPage="/projects">
  <div class="max-w-2xl mx-auto px-6 py-12 md:py-16">
    <!-- Page header -->
    <div class="flex items-center gap-2 mb-3">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-muted-foreground"
        aria-hidden="true"
      >
        <path d="M3 3h7v7H3z"></path>
        <path d="M14 3h7v7h-7z"></path>
        <path d="M14 14h7v7h-7z"></path>
        <path d="M3 14h7v7H3z"></path>
      </svg>
      <span
        class="text-xs text-muted-foreground font-medium uppercase tracking-wider"
        >Work</span
      >
    </div>
    <h1 class="text-3xl font-bold tracking-tight mb-2">Projects</h1>
    <p class="text-muted-foreground text-sm mb-10">
      Things I've built, am building, or have shipped.
    </p>

    <!-- Project list -->
    <div class="grid gap-4">
      {projects.map((project) => (
        <div class="card">
          <section>
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 flex-wrap mb-1">
                  <h2 class="text-base font-semibold text-foreground leading-snug">
                    {project.data.title}
                  </h2>
                  <span class={`${statusClass[project.data.status] ?? "badge-outline"} text-xs`}>
                    {statusLabel[project.data.status] ?? project.data.status}
                  </span>
                </div>
                <p class="text-sm text-muted-foreground leading-relaxed">
                  {project.data.description}
                </p>
                {project.data.tags && project.data.tags.length > 0 && (
                  <div class="flex gap-1.5 flex-wrap mt-3">
                    {project.data.tags.map((tag) => (
                      <span class="badge-outline text-xs">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <div class="flex items-center gap-3 shrink-0">
                {project.data.github && (
                  <a
                    href={project.data.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-muted-foreground hover:text-foreground transition-colors"
                    aria-label={`${project.data.title} on GitHub`}
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                      <path d="M9 18c-4.51 2-5-2-7-2"></path>
                    </svg>
                  </a>
                )}
                {project.data.url && (
                  <a
                    href={project.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-muted-foreground hover:text-foreground transition-colors"
                    aria-label={`${project.data.title} website`}
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M15 3h6v6"></path>
                      <path d="M10 14 21 3"></path>
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </section>
        </div>
      ))}
    </div>
  </div>
</Layout>
