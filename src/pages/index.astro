---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../site.config";

const featuredProjects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => {
    if (!a.data.date && !b.data.date) return 0;
    if (!a.data.date) return 1;
    if (!b.data.date) return -1;
    return b.data.date.valueOf() - a.data.date.valueOf();
  });

const statusLabel: Record<string, string> = {
  active: "Active",
  wip: "WIP",
  archived: "Archived",
};
---

<Layout title="About" currentPage="/">
  <div class="max-w-2xl mx-auto px-6 py-12 md:py-16">
    <!-- Page header -->
    <div class="mb-10">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">
          {siteConfig.name}
        </h1>
        <p class="mt-1 text-muted-foreground">{siteConfig.location}</p>
      </div>

      <!-- Role badges -->
      <div class="flex flex-wrap gap-2 mt-5">
        {siteConfig.roles.map((role) => (
          <span class="badge-secondary">{role}</span>
        ))}
      </div>
    </div>

    <!-- Bio card -->
    <div class="card mb-6">
      <header>
        <h2>About</h2>
      </header>
      <section>
        <p class="text-sm text-muted-foreground leading-relaxed">
          {siteConfig.bio}
        </p>
      </section>
    </div>

    <!-- Featured Projects -->
    {featuredProjects.length > 0 && (
      <div class="card mb-6">
        <header>
          <h2>Projects</h2>
          <p>Things I'm building or have built.</p>
        </header>
        <section>
          <ul class="space-y-4">
            {featuredProjects.map((project) => (
              <li>
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-sm font-medium text-foreground">
                        {project.data.title}
                      </span>
                      <span class="badge-secondary text-xs">
                        {statusLabel[project.data.status] ?? project.data.status}
                      </span>
                    </div>
                    <p class="text-xs text-muted-foreground mt-0.5 leading-relaxed">
                      {project.data.description}
                    </p>
                    {project.data.tags && project.data.tags.length > 0 && (
                      <div class="flex gap-1.5 flex-wrap mt-2">
                        {project.data.tags.map((tag) => (
                          <span class="badge-outline text-xs">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    {project.data.github && (
                      <a
                        href={project.data.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-muted-foreground hover:text-foreground transition-colors"
                        aria-label={`${project.data.title} on GitHub`}
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="14"
                          height="14"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                          <path d="M9 18c-4.51 2-5-2-7-2"></path>
                        </svg>
                      </a>
                    )}
                    {project.data.url && (
                      <a
                        href={project.data.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-muted-foreground hover:text-foreground transition-colors"
                        aria-label={`${project.data.title} website`}
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="14"
                          height="14"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="M15 3h6v6"></path>
                          <path d="M10 14 21 3"></path>
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              </li>
            ))}
          </ul>
          <div class="mt-4 pt-3 border-t border-border">
            <a href="/projects" class="text-xs text-muted-foreground hover:text-foreground transition-colors">
              View all projects →
            </a>
          </div>
        </section>
      </div>
    )}

    <!-- Contact / CTA -->
    <div class="flex flex-wrap gap-3">
      {siteConfig.social.email && (
        <a href={`mailto:${siteConfig.social.email}`} class="btn-outline">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m22 2-7 20-4-9-9-4Z"></path>
            <path d="M22 2 11 13"></path>
          </svg>
          Get in touch
        </a>
      )}
      {siteConfig.newsletter.enabled && (
        <a href="/newsletter" class="btn-secondary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
          Subscribe to newsletter
        </a>
      )}
    </div>
  </div>
</Layout>
